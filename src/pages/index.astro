---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('posts')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<BaseLayout title="须弥芥子 - 陈夏亮的博客">
  <main>
    <h1>📝 须弥芥子</h1>
    <p>记录生活、工作与思考</p>
    
    <h2>最新文章</h2>
    <ul>
      {posts.map((post) => (
        <li>
          <time datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString('zh-CN', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            })}
          </time>
          <a href={`/posts/${post.slug}/`}>{post.data.title}</a>
        </li>
      ))}
    </ul>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem;
  }
  h1 {
    color: #2c3e50;
  }
  ul {
    list-style: none;
    padding: 0;
  }
  li {
    margin: 1rem 0;
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  time {
    color: #666;
    font-size: 0.9rem;
    min-width: 100px;
  }
  a {
    color: #3498db;
    text-decoration: none;
  }
  a:hover {
    text-decoration: underline;
  }
</style>
